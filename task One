from scapy.all import sniff, IP, TCP, UDP, ICMP, Raw
from datetime import datetime


def print_line():
    print("=" * 70)


def packet_callback(packet):
    print_line()
    print("Packet Captured at:", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))

    # Check if packet has IP layer
    if packet.haslayer(IP):
        ip_layer = packet[IP]

        print(f"Source IP      : {ip_layer.src}")
        print(f"Destination IP : {ip_layer.dst}")

        protocol = ip_layer.proto

        if protocol == 6:
            print("Protocol       : TCP")
        elif protocol == 17:
            print("Protocol       : UDP")
        elif protocol == 1:
            print("Protocol       : ICMP")
        else:
            print(f"Protocol       : {protocol}")

        print(f"Packet Length  : {len(packet)} bytes")

        # TCP Information
        if packet.haslayer(TCP):
            tcp = packet[TCP]
            print(f"Source Port    : {tcp.sport}")
            print(f"Destination Port: {tcp.dport}")
            print(f"Flags          : {tcp.flags}")

        # UDP Information
        elif packet.haslayer(UDP):
            udp = packet[UDP]
            print(f"Source Port    : {udp.sport}")
            print(f"Destination Port: {udp.dport}")

        # ICMP Information
        elif packet.haslayer(ICMP):
            icmp = packet[ICMP]
            print(f"ICMP Type      : {icmp.type}")
            print(f"ICMP Code      : {icmp.code}")

        # Payload
        if packet.haslayer(Raw):
            try:
                payload = packet[Raw].load.decode(errors="ignore")
                if payload.strip():
                    print("\nPayload:")
                    print(payload[:300])  # Display first 300 characters
            except:
                print("Payload: Binary Data")

    else:
        print("Non-IP Packet")

    print_line()


def main():
    print("=" * 70)
    print("        BASIC NETWORK SNIFFER USING SCAPY")
    print("=" * 70)
    print("Press Ctrl + C to stop capturing packets.\n")

    sniff(prn=packet_callback, store=False)


if __name__ == "__main__":
    main()
